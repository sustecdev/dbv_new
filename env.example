# Copy this file to .env and configure your settings
# cp env.example .env

# Database Configuration
DB_HOST=localhost
DB_NAME=dbv_project
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

# YEMChain API
YEMCHAIN_API_BASE=http://91.98.180.218/api
YEMCHAIN_API_KEY=your_yemchain_api_key_here
VAULT_ACCOUNT_ID=your_vault_account_id_here

# Stellar Network Configuration
ASSET_CODE=DB
HORIZON_NETWORK=public
ASSET_ISSUER=your_asset_issuer_address_here
ACCOUNT_OWNER=your_account_owner_address_here
ACCOUNT_VAULT=your_account_vault_address_here
EXPLORER_URL=https://lumenscan.io

# CA bundle for cURL SSL (fixes "unable to get local issuer certificate" on Windows)
# CURL_CA_BUNDLE=c:/path/to/cacert.pem
# CURL_SSL_VERIFY=false  # Set to false only if CA bundle fails (local dev only)

# SafeZone
SAFEZONE_PIN_CHECK=https://safe.zone/signup/check_pin_api.php
SAFEZONE_TAX_COUNTRY_API_KEY=
# API key for getrefby.php - referrer lookup (referral commission)
SAFEZONE_GETREFBY_API_KEY=

# Authentication Whitelist Settings (comma-separated UIDs when enabled)
SAFEZONE_UID_WHITELIST_ENABLED=false
SAFEZONE_ALLOWED_UIDS=1290033,789,509

# Worker Secret (generate a random string)
WORKER_SECRET=your_worker_secret_here
# Base URL for internal worker trigger (default: 127.0.0.1 to prevent SSRF)
TRIGGER_BASE_URL=http://127.0.0.1

# Set to true to completely disable all workers (manual-only mode)
# WORKERS_DISABLED=true

# Stellar Secret Key (CRITICAL - Never commit to git!)
STELLAR_SECRET_KEY=

# Application Settings
APP_DEBUG=false
APP_NAME=DBV Bridge
ALLOW_DEV_SET_UID=false

# Bootstrap admin UID (always has admin access - set in .env for production)
BOOTSTRAP_ADMIN_UID=1290033

# Withdrawal Fee Settings
WITHDRAWAL_FEE_ENABLED=true
WITHDRAWAL_FEE_USDD=2.50
# Commission to referrer (from fee) when referred user withdraws
REFERRAL_COMMISSION_USDD=0.50

# Blocked withdrawal addresses (contract/issuer - comma-separated)
BLOCKED_WITHDRAWAL_ADDRESSES=GA25G3T4EYKYCCI6UGWUCCKUBO26ALELYL2W6RJJMQJ2EIPNO3LOFAHG,0xaed72bac1da87a9ed09b1de1a54590ba1124c734

# Daily Withdrawal Limits (in DBV) - Set to 0 to disable
STELLAR_DAILY_WITHDRAWAL_LIMIT=0
BSC_DAILY_WITHDRAWAL_LIMIT=0
ETH_DAILY_WITHDRAWAL_LIMIT=0

# Binance Smart Chain
BSC_WITHDRAWAL_FEE_ENABLED=true
BSC_WITHDRAWAL_FEE_USDD=2.50
BINANCE_NETWORK=mainnet
BSC_RPC_URL=https://bsc-dataseed.binance.org/
BSC_VAULT_ADDRESS=
BSC_VAULT_PRIVATE_KEY=
BSC_TOKEN_CONTRACT=
BSC_CHAIN_ID=56
BSC_EXPLORER=https://bscscan.com
BSC_GAS_PRICE=5000000000
BSC_GAS_LIMIT=100000

# Ethereum
ETH_WITHDRAWAL_FEE_ENABLED=false
ETH_WITHDRAWAL_FEE_USDD=2.50
ETHEREUM_NETWORK=mainnet
ETH_RPC_URL=https://cloudflare-eth.com
ETH_VAULT_ADDRESS=
ETH_VAULT_PRIVATE_KEY=
ETH_TOKEN_CONTRACT=
ETH_CHAIN_ID=1
ETH_EXPLORER=https://etherscan.io
ETH_GAS_PRICE=20000000000
ETH_GAS_LIMIT=100000

# WalletConnect (for admin "Complete with Wallet" - get project ID from cloud.walletconnect.com)
WALLETCONNECT_PROJECT_ID=

# Admin wallet whitelist - restrict which addresses can complete manual withdrawals (BSC/Ethereum)
ADMIN_WALLET_WHITELIST_ENABLED=false
ADMIN_WALLET_WHITELIST=0xYourAddress1,0xYourAddress23308d84fe8daa1e8a2d4ff761d5d662f

# YEMChain Bypass (TESTING ONLY - set false for production)
YEMCHAIN_BYPASS=false

# SafeIdent Whitelist
SAFEIDENT_WHITELIST_ENABLED=false
